# Environment Configuration Template
# Copy this file to .env and fill in your values

# ===========================================
# APPLICATION
# ===========================================
APP_NAME="National Road Intelligence Platform"
APP_ENV=development
APP_SECRET_KEY=your-super-secret-key-change-in-production
APP_DEBUG=true
APP_PORT=8000

# ===========================================
# DATABASE (PostgreSQL)
# ===========================================
DATABASE_URL=postgresql://nrip_user:nrip_password@localhost:5432/nrip_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nrip_db
DB_USER=nrip_user
DB_PASSWORD=nrip_password

# ===========================================
# REDIS (Celery Broker)
# ===========================================
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ===========================================
# JWT AUTHENTICATION
# ===========================================
JWT_SECRET_KEY=your-jwt-secret-key-change-this
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ===========================================
# AI / DETECTION
# ===========================================
YOLO_MODEL_PATH=ai/models/pothole_detector.pt
CONFIDENCE_THRESHOLD=0.45
MAX_FRAME_EXTRACTION=30
AI_SERVICE_URL=http://localhost:8001

# ===========================================
# BLOCKCHAIN (Polygon Testnet / Simulation)
# ===========================================
BLOCKCHAIN_MODE=simulation
POLYGON_RPC_URL=https://rpc-mumbai.maticvigil.com
POLYGON_CHAIN_ID=80001
DEPLOYER_PRIVATE_KEY=your-wallet-private-key
CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# ===========================================
# SATELLITE / GEO DATA
# ===========================================
GOOGLE_EARTH_ENGINE_KEY=your-gee-service-account-key
SENTINEL_HUB_CLIENT_ID=your-sentinel-hub-client-id
SENTINEL_HUB_CLIENT_SECRET=your-sentinel-hub-secret
DEFAULT_CITY_LAT=28.6139
DEFAULT_CITY_LNG=77.2090

# ===========================================
# EMAIL NOTIFICATIONS
# ===========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@nrip.gov.in
SMTP_PASSWORD=your-smtp-password
NOTIFICATION_EMAIL=admin@nrip.gov.in

# ===========================================
# FILE STORAGE
# ===========================================
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=100
ALLOWED_EXTENSIONS=jpg,jpeg,png,mp4,avi,mov

# ===========================================
# FRONTEND
# ===========================================
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_MAP_CENTER_LAT=20.5937
NEXT_PUBLIC_MAP_CENTER_LNG=78.9629
NEXT_PUBLIC_MAP_ZOOM=5
